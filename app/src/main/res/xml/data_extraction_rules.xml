<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- The encrypted BYO AI key store and its Keystore-wrapped keyset are device-bound; exclude
         them from both cloud backup and device-to-device transfer (E7-G2). -->
    <cloud-backup>
        <exclude domain="sharedpref" path="ai_secret_store.xml" />
        <exclude domain="sharedpref" path="ai_secret_keyset.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="ai_secret_store.xml" />
        <exclude domain="sharedpref" path="ai_secret_keyset.xml" />
    </device-transfer>
</data-extraction-rules>
