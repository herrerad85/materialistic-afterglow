<!--
  Inline find-in-thread bar. A thin overlay row anchored to the top of the comment list, it does not
  reorder or remove comment rows (find-in-page, not filtering). Starts hidden ; the comments-tab menu
  action toggles it. Colours use M3 role attrs so the bar reads on light, dark, and AMOLED.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@id/comment_find_bar"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:visibility="gone"
    android:elevation="4dp"
    android:background="?attr/colorCardBackground"
    android:paddingLeft="@dimen/margin"
    android:paddingRight="@dimen/margin"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <EditText
        android:id="@+id/comment_find_query"
        android:hint="@string/find_in_thread_hint"
        android:inputType="text"
        android:imeOptions="actionSearch"
        android:maxLines="1"
        android:singleLine="true"
        android:textColor="?android:attr/textColorPrimary"
        android:textColorHint="?android:attr/textColorSecondary"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/comment_find_count"
        android:minWidth="48dp"
        android:gravity="center"
        android:textColor="?android:attr/textColorSecondary"
        android:paddingLeft="@dimen/padding"
        android:paddingRight="@dimen/padding"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <ImageButton
        android:id="@+id/comment_find_prev"
        android:src="@drawable/ic_expand_less_white_24dp"
        app:tint="?android:attr/textColorPrimary"
        android:contentDescription="@string/comment_search_previous"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_width="48dp"
        android:layout_height="48dp" />

    <ImageButton
        android:id="@+id/comment_find_next"
        android:src="@drawable/ic_expand_more_white_24dp"
        app:tint="?android:attr/textColorPrimary"
        android:contentDescription="@string/comment_search_next"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_width="48dp"
        android:layout_height="48dp" />

    <ImageButton
        android:id="@+id/comment_find_close"
        android:src="@drawable/ic_clear_white_24dp"
        app:tint="?android:attr/textColorPrimary"
        android:contentDescription="@string/comment_search_close"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_width="48dp"
        android:layout_height="48dp" />

</LinearLayout>
